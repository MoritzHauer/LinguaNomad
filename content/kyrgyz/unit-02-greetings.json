  "sentences": [
    {
      "id": "ky-sent-u2-01",
      "languageCode": "ky",
      "text": "Саламатсызбы!",
      "transliteration": "Salamatsyzby!",
      "translation": "Hello!",
      "sourceIds": ["linguanomad-original-kyrgyz-starter-2026"]
    },
    {
      "id": "ky-sent-u2-02",
      "languageCode": "ky",
      "text": "Атыңыз ким?",
      "transliteration": "Atynyz kim?",
      "translation": "What is your name?",
      "sourceIds": ["linguanomad-original-kyrgyz-starter-2026"]
    },
    {
      "id": "ky-sent-u2-03",
      "languageCode": "ky",
      "text": "Менин атым Алмаз.",
      "transliteration": "Menin atym Almaz.",
      "translation": "My name is Almaz.",
      "sourceIds": ["linguanomad-original-kyrgyz-starter-2026"]
    },
    {
      "id": "ky-sent-u2-04",
      "languageCode": "ky",
      "text": "Мен студентмин.",
      "transliteration": "Men studentmin.",
      "translation": "I am a student.",
      "sourceIds": ["linguanomad-original-kyrgyz-starter-2026"]
    },
    {
      "id": "ky-sent-u2-05",
      "languageCode": "ky",
      "text": "Жакшы, рахмат.",
      "transliteration": "Zhakshy, rakhmat.",
      "translation": "Good, thank you.",
      "sourceIds": ["linguanomad-original-kyrgyz-starter-2026"]
    },
    {
      "id": "ky-sent-u2-06",
      "languageCode": "ky",
      "text": "Таанышканыма кубанычтамын.",
      "transliteration": "Taanyshkanyma kubanychtamyn.",
      "translation": "Nice to meet you.",
      "sourceIds": ["linguanomad-original-kyrgyz-starter-2026"]
    },
    {
      "id": "ky-sent-u2-07",
      "languageCode": "ky",
      "text": "Кош келиңиз!",
      "transliteration": "Kosh keliniz!",
      "translation": "Welcome!",
      "sourceIds": ["linguanomad-original-kyrgyz-starter-2026"]
    },
    {
      "id": "ky-sent-u2-08",
      "languageCode": "ky",
      "text": "Сиздин атыңыз ким?",
      "transliteration": "Sizdin atynyz kim?",
      "translation": "What is your name? (polite)",
      "sourceIds": ["linguanomad-original-kyrgyz-starter-2026"]
    }
  ],
  "grammarNotes": [
    {
      "id": "ky-grammar-u2-01",
      "title": "Personal pronouns: мен, сен, сиз",
      "summary": "Kyrgyz has a polite and casual second-person pronoun distinction. Use сиз (polite) for elders, strangers, and first meetings. Use сен (casual) only with peers and close friends once you know them well. For now, defaulting to сиз in everything makes you sound respectful and safe. The first-person мен (I) works the same in all registers.",
      "sourceIds": ["linguanomad-original-kyrgyz-starter-2026"]
    },
    {
      "id": "ky-grammar-u2-02",
      "title": "The copula suffix -мин makes identity statements",
      "summary": "To say 'I am [something]' in Kyrgyz, attach the suffix -мин directly to the noun. Мен студентмин means I am a student. The suffix form changes slightly with vowel harmony — front-vowel words use -мин, back-vowel words use -мын. For beginner sentences, the pattern Мен ... -мин is a safe and useful early tool.",
      "sourceIds": ["linguanomad-original-kyrgyz-starter-2026"]
    }
  ],
